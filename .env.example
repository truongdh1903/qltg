# Application
APP_ENV=development
APP_PORT=8080
APP_SECRET_KEY=change-this-to-a-random-32-byte-secret

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=time_tracker
DB_USER=root
DB_PASSWORD=your_password
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5

# Session
SESSION_COOKIE_NAME=tt_session
SESSION_DURATION_DAYS=7

# Email (Resend)
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Time Tracker
RESEND_API_KEY=re_your_api_key

# URLs
APP_BASE_URL=http://localhost:8080

# Timezone
TZ=Asia/Ho_Chi_Minh
